<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.AuctionDetailViewController">

    <HBox alignment="CENTER_LEFT" spacing="14.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-title" text="🎯 Chi tiết phiên đấu giá" />
            <Label styleClass="page-subtitle" text="Xem thông tin sản phẩm và đặt giá thầu" />
        </VBox>
        <Button styleClass="btn-ghost" text="← Quay lại danh sách" onAction="#handleBack" />
    </HBox>

    <!-- Top: search by auction id -->
    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="card">
        <Label styleClass="form-label" text="Phiên đấu giá ID:" />
        <TextField fx:id="txtAuctionId" prefHeight="36.0" prefWidth="160.0" promptText="VD: 1" />
        <Button styleClass="btn-primary" text="Xem chi tiết" onAction="#handleLoad" />
    </HBox>

    <!-- Info card -->
    <HBox spacing="18.0">
        <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="page-title" text="Thông tin sản phẩm" />
            <HBox spacing="20.0">
                <VBox spacing="6.0">
                    <Label styleClass="form-label" text="Tên sản phẩm" />
                    <Label fx:id="lblItemName" text="-" />
                </VBox>
                <VBox spacing="6.0">
                    <Label styleClass="form-label" text="Danh mục" />
                    <Label fx:id="lblItemType" text="-" />
                </VBox>
            </HBox>
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Mô tả" />
                <Label fx:id="lblItemDesc" wrapText="true" text="-" />
            </VBox>
        </VBox>

        <VBox spacing="10.0" styleClass="card" minWidth="280">
            <Label styleClass="page-title" text="Tình trạng phiên" />
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label styleClass="form-label" text="Trạng thái:" />
                <Label fx:id="lblStatus" styleClass="status-open" text="OPEN" />
            </HBox>
            <Label styleClass="form-label" text="Giá khởi điểm" />
            <Label fx:id="lblStart" styleClass="stat-value" text="0 ₫" />
            <Label styleClass="form-label" text="Giá hiện tại" />
            <Label fx:id="lblCurrent" styleClass="stat-value" text="0 ₫" />
            <Label styleClass="form-label" text="Kết thúc lúc" />
            <Label fx:id="lblEnd" text="-" />
        </VBox>
    </HBox>

    <!-- Place bid -->
    <VBox spacing="10.0" styleClass="card">
        <Label styleClass="page-title" text="💰 Đặt giá thầu" />
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="txtBidAmount" prefHeight="38.0" prefWidth="240.0" promptText="Số tiền bạn muốn đặt (VNĐ)" />
            <Button fx:id="btnPlaceBid" styleClass="btn-warning" text="🚀 PLACE BID" onAction="#handlePlaceBid" />
        </HBox>
        <Label fx:id="lblBidResult" styleClass="page-subtitle" text="" />
    </VBox>

    <!-- Recent bids -->
    <VBox spacing="10.0" styleClass="card" VBox.vgrow="ALWAYS">
        <Label styleClass="page-title" text="📜 Lịch sử đặt giá phiên này" />
        <TableView fx:id="tblBids" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colBidId"     prefWidth="60.0"  text="ID" />
                <TableColumn fx:id="colBidder"    prefWidth="160.0" text="Bidder" />
                <TableColumn fx:id="colAmount"    prefWidth="160.0" text="Số tiền" />
                <TableColumn fx:id="colBidTime"   prefWidth="200.0" text="Thời điểm" />
            </columns>
        </TableView>
    </VBox>

    <padding><Insets bottom="0" left="0" right="0" top="0" /></padding>
</VBox>
