<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.OpenAuctionViewController">

    <HBox alignment="CENTER_LEFT" spacing="14.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-title" text="🚀 Mở phiên đấu giá" />
            <Label styleClass="page-subtitle" text="Chọn sản phẩm và cấu hình thời gian, giá khởi điểm" />
        </VBox>
        <Button styleClass="btn-ghost" text="← Quay lại" onAction="#handleBack" />
    </HBox>

    <VBox spacing="14.0" styleClass="card" maxWidth="720">

        <VBox spacing="6.0">
            <Label styleClass="form-label" text="Sản phẩm" />
            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <ComboBox fx:id="cbItem" prefHeight="38.0" maxWidth="Infinity" promptText="Chọn sản phẩm cần đấu giá..." HBox.hgrow="ALWAYS" />
                <Button styleClass="btn-ghost" text="🔄" onAction="#handleReloadItems" />
            </HBox>
        </VBox>

        <HBox spacing="14.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="Giá khởi điểm (VNĐ)" />
                <TextField fx:id="txtStartPrice" prefHeight="38.0" promptText="VD: 5000000" />
            </VBox>
        </HBox>

        <HBox spacing="14.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="Ngày bắt đầu" />
                <DatePicker fx:id="dpStart" prefHeight="38.0" maxWidth="Infinity" />
            </VBox>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="Giờ bắt đầu (HH:mm)" />
                <TextField fx:id="txtStartTime" prefHeight="38.0" promptText="VD: 09:00" />
            </VBox>
        </HBox>

        <HBox spacing="14.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="Ngày kết thúc" />
                <DatePicker fx:id="dpEnd" prefHeight="38.0" maxWidth="Infinity" />
            </VBox>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="Giờ kết thúc (HH:mm)" />
                <TextField fx:id="txtEndTime" prefHeight="38.0" promptText="VD: 18:00" />
            </VBox>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="btn-ghost"   text="Hủy"   onAction="#handleBack" />
            <Button styleClass="btn-warning" text="🚀 MỞ PHIÊN" onAction="#handleOpenAuction" />
        </HBox>
    </VBox>
</VBox>
