<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.MyItemsViewController">

    <HBox alignment="CENTER_LEFT" spacing="14.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-title" text="📦 Sản phẩm của tôi" />
            <Label styleClass="page-subtitle" text="Quản lý các sản phẩm bạn đã đăng để đấu giá" />
        </VBox>
        <Button styleClass="btn-ghost" text="🔄 Tải lại" onAction="#handleReload" />
        <Button styleClass="btn-success" text="➕ Thêm sản phẩm mới" onAction="#handleAddNew" />
    </HBox>

    <TableView fx:id="tblItems" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"      prefWidth="60.0"  text="ID" />
            <TableColumn fx:id="colName"    prefWidth="220.0" text="Tên sản phẩm" />
            <TableColumn fx:id="colType"    prefWidth="130.0" text="Danh mục" />
            <TableColumn fx:id="colPrice"   prefWidth="160.0" text="Giá khởi điểm" />
            <TableColumn fx:id="colDesc"    prefWidth="260.0" text="Mô tả" />
            <TableColumn fx:id="colAction"  prefWidth="200.0" text="Thao tác" />
        </columns>
    </TableView>
</VBox>
