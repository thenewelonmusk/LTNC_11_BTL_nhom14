<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.MyAuctionsViewController">

    <HBox alignment="CENTER_LEFT" spacing="14.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-title" text="🛎 Phiên đấu giá của tôi" />
            <Label styleClass="page-subtitle" text="Quản lý các phiên đấu giá bạn đã mở" />
        </VBox>
        <Button styleClass="btn-ghost"  text="🔄 Tải lại" onAction="#handleReload" />
        <Button styleClass="btn-success" text="🚀 Mở phiên mới" onAction="#handleNewAuction" />
    </HBox>

    <TableView fx:id="tblAuctions" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        prefWidth="60.0"  text="ID" />
            <TableColumn fx:id="colItemName"  prefWidth="200.0" text="Sản phẩm" />
            <TableColumn fx:id="colStart"     prefWidth="130.0" text="Giá khởi điểm" />
            <TableColumn fx:id="colCurrent"   prefWidth="130.0" text="Giá hiện tại" />
            <TableColumn fx:id="colStartTime" prefWidth="160.0" text="Bắt đầu" />
            <TableColumn fx:id="colEndTime"   prefWidth="160.0" text="Kết thúc" />
            <TableColumn fx:id="colStatus"    prefWidth="110.0" text="Trạng thái" />
            <TableColumn fx:id="colAction"    prefWidth="120.0" text="Thao tác" />
        </columns>
    </TableView>
</VBox>
