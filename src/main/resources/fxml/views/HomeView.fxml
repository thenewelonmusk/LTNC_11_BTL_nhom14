<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.HomeViewController">

    <VBox spacing="4.0">
        <Label fx:id="lblWelcome" styleClass="page-title" text="Chào mừng quay lại 👋" />
        <Label styleClass="page-subtitle" text="Tổng quan nhanh về tài khoản của bạn" />
    </VBox>

    <!-- Stat cards -->
    <FlowPane hgap="16.0" vgap="16.0">
        <VBox spacing="6.0" styleClass="stat-card">
            <Label styleClass="stat-label" text="Vai trò của bạn" />
            <Label fx:id="lblRole" styleClass="stat-value" text="-" />
        </VBox>
        <VBox spacing="6.0" styleClass="stat-card">
            <Label styleClass="stat-label" text="User ID" />
            <Label fx:id="lblUserId" styleClass="stat-value" text="-" />
        </VBox>
        <VBox spacing="6.0" styleClass="stat-card">
            <Label styleClass="stat-label" text="Trạng thái kết nối" />
            <Label fx:id="lblConn" styleClass="stat-value" text="Đang kiểm tra..." />
        </VBox>
    </FlowPane>

    <!-- Quick actions -->
    <VBox spacing="14.0" styleClass="card">
        <Label styleClass="page-title" text="Hành động nhanh" />
        <FlowPane fx:id="quickActions" hgap="12.0" vgap="12.0" />
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER" spacing="0">
        <Label styleClass="page-subtitle" text="© 2025 Nhóm 14 – Auction System" />
    </HBox>

    <padding><Insets bottom="0" left="0" right="0" top="0" /></padding>
</VBox>
