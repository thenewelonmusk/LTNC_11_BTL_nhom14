<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.BrowseAuctionsViewController">

    <VBox spacing="4.0">
        <Label styleClass="page-title" text="🔍 Danh sách phiên đấu giá" />
        <Label styleClass="page-subtitle" text="Khám phá các phiên đang mở và tham gia đặt giá" />
    </VBox>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" prefHeight="36.0" prefWidth="280.0" promptText="Tìm theo tên sản phẩm hoặc ID..." />
        <Button styleClass="btn-ghost" text="Tìm kiếm" onAction="#handleSearch" />
        <Region HBox.hgrow="ALWAYS" />
        <Button styleClass="btn-primary" text="🔄 Tải lại" onAction="#handleReload" />
    </HBox>

    <TableView fx:id="tblAuctions" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        prefWidth="60.0"  text="ID" />
            <TableColumn fx:id="colItemName"  prefWidth="220.0" text="Sản phẩm" />
            <TableColumn fx:id="colStart"     prefWidth="130.0" text="Giá khởi điểm" />
            <TableColumn fx:id="colCurrent"   prefWidth="130.0" text="Giá hiện tại" />
            <TableColumn fx:id="colEndTime"   prefWidth="170.0" text="Kết thúc lúc" />
            <TableColumn fx:id="colStatus"    prefWidth="110.0" text="Trạng thái" />
            <TableColumn fx:id="colAction"    prefWidth="140.0" text="Thao tác" />
        </columns>
    </TableView>
</VBox>
