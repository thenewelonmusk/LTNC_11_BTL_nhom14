<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.MyBidsViewController">

    <HBox alignment="CENTER_LEFT" spacing="14.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-title" text="📜 Lịch sử đặt giá của tôi" />
            <Label styleClass="page-subtitle" text="Tất cả các lần đặt giá bạn đã thực hiện" />
        </VBox>
        <Button styleClass="btn-primary" text="🔄 Tải lại" onAction="#handleReload" />
    </HBox>

    <TableView fx:id="tblMyBids" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        prefWidth="60.0"  text="ID" />
            <TableColumn fx:id="colAuctionId" prefWidth="100.0" text="Phiên #" />
            <TableColumn fx:id="colItemName"  prefWidth="240.0" text="Sản phẩm" />
            <TableColumn fx:id="colAmount"    prefWidth="150.0" text="Số tiền" />
            <TableColumn fx:id="colBidTime"   prefWidth="180.0" text="Thời điểm" />
            <TableColumn fx:id="colResult"    prefWidth="140.0" text="Kết quả" />
        </columns>
    </TableView>

    <Label fx:id="lblEmpty" styleClass="page-subtitle" text="" />
</VBox>
